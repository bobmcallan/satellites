# satellites v4 — local development environment
# Copy this file to .env, edit as needed, then run ./scripts/deploy.sh up.
# Never commit .env (it's already in .gitignore).

# Server --------------------------------------------------------------------
PORT=8080
ENV=dev
LOG_LEVEL=info
DEV_MODE=true

# Database ------------------------------------------------------------------
# docker-compose resolves "surrealdb" to the sibling container; off-compose
# change to ws://root:root@localhost:8000/rpc/satellites/satellites.
DB_DSN=ws://root:root@surrealdb:8000/rpc/satellites/satellites

# Documents -----------------------------------------------------------------
# Container-side mount point for the repo's docs/ tree (see docker-compose.yml).
DOCS_DIR=/app/docs

# Auth: basic + DevMode -----------------------------------------------------
# When ENV=dev and DEV_MODE=true, this credential authenticates without OAuth.
# Disabled entirely in prod.
DEV_USERNAME=dev@local
DEV_PASSWORD=change-me

# Auth: OAuth providers -----------------------------------------------------
# Leave empty to disable the provider; /auth/<provider>/start returns 404.
# Register OAuth apps at:
#   https://console.cloud.google.com/apis/credentials
#   https://github.com/settings/applications/new
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=http://localhost:8080

# MCP -----------------------------------------------------------------------
# Comma-separated Bearer tokens accepted on /mcp when no session cookie.
SATELLITES_API_KEYS=
